# ---------------------------------------------------------------------------
# Rasoi Radar — API (FastAPI) environment variables
# Copy to `.env` and fill in values for local development.
# ---------------------------------------------------------------------------

# Async SQLAlchemy/asyncpg connection string. Note the "+asyncpg" driver.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rasoi_radar

# --- Auth (used from PR-1 onward) ------------------------------------------
# Secret for signing short-lived (15 min) access JWTs. Use a long random value.
JWT_SECRET=change-me-access-secret
# Separate secret for signing rotating (30 day) refresh JWTs.
JWT_REFRESH_SECRET=change-me-refresh-secret

# --- Translation provider (multilingual ingredient catalog) ----------------
# One of: google | deepl | libretranslate | none
TRANSLATE_PROVIDER=none
TRANSLATE_API_KEY=

# --- Geocoding provider (store lat/lng + earthdistance search) -------------
# One of: google | mapbox | nominatim | none
GEOCODE_PROVIDER=none
GEOCODE_API_KEY=

# --- CORS ------------------------------------------------------------------
# Comma-separated list of allowed browser origins in addition to localhost.
# Set this to your Vercel production domain.
CORS_ORIGINS=http://localhost:3000
# Regex for origins to allow in addition to the list above. Defaults (in code)
# to this project's Vercel deployments so preview URLs (which change per commit)
# work. Override to match your own domain, or set to "" to disable.
CORS_ORIGIN_REGEX=^https://bulk-ingredient-finder-web[a-z0-9-]*\.vercel\.app$

# --- Tenancy ---------------------------------------------------------------
# "true"  = multi-tenant (self-registration on; every request needs a session).
# "false" = single-restaurant dogfood mode (org auto-created by seed, no login).
MULTI_TENANT=true

# --- Runtime ---------------------------------------------------------------
# "development" enables human-readable console logs; anything else = JSON logs.
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Observability (PR-8) --------------------------------------------------
# Sentry DSN for the API. Leave blank to disable error reporting.
SENTRY_DSN=
