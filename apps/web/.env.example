# ---------------------------------------------------------------------------
# Rasoi Radar — Web (Next.js) environment variables
# Copy to `.env.local` and fill in values. Only NEXT_PUBLIC_* are exposed to
# the browser bundle; everything else stays server-side.
# ---------------------------------------------------------------------------

# Base URL of the FastAPI backend (used by the web app to call /api/v1/*).
# Local dev default:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Multi-tenant UI switch. Mirrors the API's MULTI_TENANT flag. When "true"
# self-registration is enabled and the app requires sign-in; "false" runs in
# single-restaurant "dogfood" mode (org auto-created by seed, no login).
NEXT_PUBLIC_MULTI_TENANT=true

# Sentry DSN for the web app (PR-8). Leave blank to disable error reporting.
NEXT_PUBLIC_SENTRY_DSN=
